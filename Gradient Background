<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Porto das Barcas gradient background — Museu do Mar</title>
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { width: 100%; height: 100%; overflow: hidden; background: #C49020; }
  .stage { position: relative; width: 100%; height: 100vh; overflow: hidden; }
  svg.bg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .demo-label {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Georgia', serif;
    font-size: 13px;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    pointer-events: none;
  }
</style>
</head>
<body>
<div class="stage">

<svg class="bg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <filter id="goo" x="-60%" y="-60%" width="220%" height="220%" color-interpolation-filters="sRGB">
      <feGaussianBlur stdDeviation="130"/>
    </filter>
  </defs>


  <rect width="1440" height="900" fill="#C49020"/>

  <g filter="url(#goo)">

    <!-- AMARELO MEIO DOURADO -->
    <circle cx="400" cy="380" r="480" fill="#D4A520" opacity="0.95">
      <animate attributeName="cx" values="400;560;340;500;400" dur="22s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
      <animate attributeName="cy" values="380;300;460;360;380" dur="22s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
    </circle>

    <!-- LARANJADO -->
    <circle cx="60" cy="480" r="340" fill="#D46018" opacity="0.90">
      <animate attributeName="cx" values="60;180;30;130;60" dur="18s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
      <animate attributeName="cy" values="480;380;540;440;480" dur="18s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
    </circle>

    <!-- ROSA -->
    <circle cx="1140" cy="400" r="520" fill="#BF7080" opacity="0.88">
      <animate attributeName="cx" values="1140;980;1220;1060;1140" dur="26s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
      <animate attributeName="cy" values="400;500;340;460;400" dur="26s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
    </circle>

    <!-- VERDE -->
    <circle cx="100" cy="840" r="420" fill="#2D6340" opacity="0.92">
      <animate attributeName="cx" values="100;240;60;180;100" dur="20s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
      <animate attributeName="cy" values="840;760;900;820;840" dur="20s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
    </circle>

    <!-- AZUL -->
    <circle cx="1380" cy="80" r="300" fill="#5A7EC0" opacity="0.80">
      <animate attributeName="cx" values="1380;1260;1420;1320;1380" dur="24s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
      <animate attributeName="cy" values="80;180;40;120;80" dur="24s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
    </circle>

    <!-- ROSA COMPLEMENTAR -->
    <circle cx="1360" cy="820" r="360" fill="#C07880" opacity="0.75">
      <animate attributeName="cx" values="1360;1200;1420;1260;1360" dur="30s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
      <animate attributeName="cy" values="820;720;880;780;820" dur="30s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
    </circle>

    <!-- DOURADO MAIS FORTE -->
    <circle cx="720" cy="160" r="380" fill="#E0B830" opacity="0.70">
      <animate attributeName="cx" values="720;860;620;780;720" dur="19s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
      <animate attributeName="cy" values="160;240;100;200;160" dur="19s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
    </circle>

    <!-- AMARELADO REFORÇADO PRO GRADIENTE -->
    <circle cx="700" cy="920" r="400" fill="#7A8B28" opacity="0.65">
      <animate attributeName="cx" values="700;560;800;640;700" dur="28s" repeatCount="indefinite" calcMode="spline" keySplines=".42 0 .58 1;.42 0 .58 1;.42 0 .58 1;.42 0 .58 1"/>
    </circle>

  </g>
</svg>

</div>
</body>
</html>
